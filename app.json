{
  "expo": {
    "name": "Yemek App",
    "slug": "yemek-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "yemekapp",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "LSApplicationQueriesSchemes": [
          "appie",
          "jumbo",
          "instagram"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#064e3b",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#064e3b"
        }
      ],
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Uygulamanın buzdolabı fotoğraflarını seçebilmesi için galeriye erişim izni gerekiyor.",
          "cameraPermission": "Fotoğraf çekebilmek için kameraya erişim izni gerekiyor."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Buzdolabını videoyla tarayabilmek için kameraya erişim izni gerekiyor.",
          "microphonePermission": "Video kaydı sırasında mikrofona erişim izni gerekiyor.",
          "recordAudioAndroid": true
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
