EXPO_PUBLIC_ANTHROPIC_API_KEY=
EXPO_PUBLIC_GOOGLE_API_KEY=
# claude | gemini — vision sağlayıcı A/B testi (envanter çıkarımı), bkz. services/vision/
EXPO_PUBLIC_VISION_PROVIDER=gemini
# true | false (varsayılan) — DENEYSEL: Gemini'ye kareler yerine ham videoyu
# native gönder, bkz. services/vision/gemini-provider.ts ve SKILL.md
EXPO_PUBLIC_GEMINI_NATIVE_VIDEO=false
# live | mock — mağaza fiyat sağlayıcıları (AH/Jumbo), bkz. services/stores/
# Tanımsızsa: web'de mock (CORS), native'de live.
EXPO_PUBLIC_STORE_PROVIDER=
# ah | jumbo | both — SADECE mock modda mağaza çökmesi simülasyonu (test)
EXPO_PUBLIC_STORE_MOCK_FAIL=
